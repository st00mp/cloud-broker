{% extends 'base.html.twig' %}

{% block title %}
	Test basic d'affichage de produits
{% endblock %}

{% block body %}
	<style>
		body {
			background-color: black;
		}

		h1 {
			color: white;
		}

		.example-wrapper {
			margin: 1em auto;
			max-width: 800px;
			width: 95%;
			font: 18px / 1.5 sans-serif;
		}
		.example-wrapper ul {
			background: black;
			color: white;
			padding: 2px 6px;
		}
	</style>

	<div class="example-wrapper">

		<h1>Liste des produits</h1>

		{% for product in products %}
			<ul>
				<li>Nom du produit :
					{{product.nom}}</li>
				<li>Prix :
					{{product.prix}}
					€</li>
			</ul>
		{% endfor %}

		{% for value in randomInt %}
			<ul>
				<li>Numéro aléatoire :
					{{ value }}</li>
			</ul>
		{% endfor %}
	</div>
{% endblock %}
